# OpenAI/Anthropic API
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Memora Configuration
MEMORA_DB_PATH=~/.local/share/memora/memories.db
MEMORA_ALLOW_ANY_TAG=1
MEMORA_EMBEDDING_MODEL=openai
MEMORA_GRAPH_PORT=8765

# Optional: Cloud storage (S3/R2)
# AWS_PROFILE=memora
# AWS_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com
# MEMORA_STORAGE_URI=s3://bucket/memories.db

# Optional: Cloudflare D1
# MEMORA_STORAGE_URI=d1://account-id/database-id
# CLOUDFLARE_API_TOKEN=your_cloudflare_token
